<Window x:Class="DrinkChoice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DrinkChoice"
        mc:Ignorable="d"
        Title="Drink Choice" Height="400" Width="400">
    
    <DockPanel x:Name="restDoc" Margin="30">
        <TextBlock DockPanel.Dock="Top" Margin="20" Text="{Binding}"/>

        <TextBlock DockPanel.Dock="Bottom" Margin="20" Text="{Binding}"/>
        <local:RestaurantControl x:Name="restCtrl"/>
    </DockPanel>
</Window>
